# Docker ignore file for EDMS project (sources root)

# Dependencies
**/node_modules/

# Build outputs
**/dist/
**/build/
**/target/

# Logs
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Environment files
.env
.env.*
!.env.example

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~

# Git
.git/
.gitignore

# OS files
.DS_Store
Thumbs.db

# Docker specific
docker/data/
**/.dockerignore
