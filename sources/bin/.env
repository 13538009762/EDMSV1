# Environment variables for EDMS Docker deployment
# Copy this file to .env and modify values as needed

# Web server port (external access)
WEB_PORT=80

# JWT secret key - CHANGE THIS IN PRODUCTION!
# Will be auto-generated if not set

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost,http://127.0.0.1

# Database URL (SQLite by default)
DATABASE_URL=sqlite:////app/data/edms.db
JWT_SECRET_KEY=0123456789abcdef:~7,10123456789abcdef:~2,10123456789abcdef:~6,10123456789abcdef:~12,10123456789abcdef:~9,10123456789abcdef:~8,10123456789abcdef:~6,10123456789abcdef:~2,10123456789abcdef:~13,10123456789abcdef:~14,10123456789abcdef:~3,10123456789abcdef:~10,10123456789abcdef:~1,10123456789abcdef:~5,10123456789abcdef:~13,10123456789abcdef:~8,10123456789abcdef:~14,10123456789abcdef:~9,10123456789abcdef:~5,10123456789abcdef:~11,10123456789abcdef:~6,10123456789abcdef:~1,10123456789abcdef:~0,10123456789abcdef:~2,10123456789abcdef:~10,10123456789abcdef:~8,10123456789abcdef:~13,10123456789abcdef:~1,10123456789abcdef:~15,10123456789abcdef:~1,10123456789abcdef:~7,10123456789abcdef:~4,1 
