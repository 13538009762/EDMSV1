# Environment variables for EDMS Docker deployment

# Web server port (external access)
WEB_PORT=80

# JWT secret key - CHANGE THIS IN PRODUCTION!
JWT_SECRET_KEY=

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost,http://127.0.0.1

# MySQL Configuration
MYSQL_ROOT_PASSWORD=edms_root_pass
MYSQL_DATABASE=edms_db
MYSQL_USER=edms_developer
MYSQL_PASSWORD=edms_dev_pass

# Database URL for SQLAlchemy
DATABASE_URL=mysql+pymysql://edms_developer:edms_dev_pass@db:3306/edms_db
